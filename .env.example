# DexVault Environment Variables

# Jira Configuration
JIRA_BASE_URL=https://singularraritylabs.atlassian.net/
JIRA_EMAIL=singularraritylabs@gmail.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PRODUCT_PROJECT_KEY=DP
JIRA_TECH_PROJECT_KEY=DV

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=SingularRarityLabs/DexVault

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dexvault

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Escrow Configuration
CASTLER_API_KEY=your_castler_api_key_here
CASTLER_API_SECRET=your_castler_api_secret_here
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Smart Contract Configuration
HARDHAT_NETWORK=testnet
PRIVATE_KEY=your_private_key_here

# Application Configuration
NODE_ENV=development
PORT=3000
API_PORT=8000

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_3D_VIEWER=true
ENABLE_ESCROW=true
ENABLE_REPUTATION=true
# JIRA_BASE_URL (not JIRA_URL) - fixed in DV-9
# JIRA_USER_EMAIL (not JIRA_EMAIL) - fixed in DV-10
